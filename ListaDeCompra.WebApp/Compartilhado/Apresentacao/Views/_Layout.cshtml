<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

    <title>@ViewBag.title - Lista De Compra</title>
</head>

<body>
    <nav>
        <div>
            <a asp-controller="Home" asp-action="Index">Clube da Leitura</a>

            <button type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#menuPrincipal"
                    aria-controls="navbarSupportedContent"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span></span>
            </button>

            <div id="menuPrincipal">
                <div>
                    <a asp-controller="Home" asp-action="Index">Início</a>
                    <a href="https://github.com/PingDev-51" target="_blank">PingDev-51</a>
                </div>
            </div>
        </div>
    </nav>

    <header style="padding: 10px 20px;">
        <h2>@ViewBag.title</h2>
    </header>

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
</body>

</html>