@using System.Security.Cryptography
@using ListaDeCompra.WebApp.ModuloProdutos.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Produtos";
}

@model List<ListarProdutoViewModel>;

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Novo</a>

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhum produto cadastrado.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle bg-white">
            <thead class="table-primary">
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Preço</th>
                    <th>Unidade De Medida</th>
                    <th>Categoria</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (ListarProdutoViewModel r in Model)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@r.Nome</td>
                        <td>@r.Preco.ToString(format:"C2")</td>
                        <td>@r.UnidadeMedida</td>
                        <td>@r.Categoria</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar" asp-route-id="@r.Id">Editar</a>
                                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir" asp-route-id="@r.Id">Excluir</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}