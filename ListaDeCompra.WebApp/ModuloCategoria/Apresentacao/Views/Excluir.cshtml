@using ListaDeCompra.WebApp.ModuloCategorias.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Categoria";
}

@model ExcluirCategoriaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Excluir" asp-route-id="@Model.Id" method="post">
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Deseja realmente excluir essa categoria?
    </div>

    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome</label>
        <input asp-for="Nome" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="Cor" class="form-label fw-semibold text-primary text-uppercase small">Cor</label>
        <input asp-for="Cor" type="text" class="form-control" disabled>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>
