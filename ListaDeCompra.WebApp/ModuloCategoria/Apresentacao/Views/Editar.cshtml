@using ListaDeCompra.WebApp.ModuloCategorias.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Edição de Categorias";
}

@model EditarCategoriaViewModel

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Editar" asp-route-id="@Model.Id" method="post">
    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome</label>
        <input asp-for="Nome" type="text" class="form-control">
        <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Cor" class="form-label fw-semibold text-primary text-uppercase small">
        Cor
        </label>

        <select asp-for="Cor" class="form-select">
            <option value="">Selecione uma Cor</option>
            <option value="Preto">Preto</option>
            <option value="Vermelho">Vermelho</option>
            <option value="Amarelo">Amearelo</option>
            <option value="Roxo">Roxo</option>
        </select>

        <span asp-validation-for="Cor" class="text-danger small fw-semibold"></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>
